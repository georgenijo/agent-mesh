# Planning-tool integration — source this (or export the vars) before starting meshd.
#
#   set -a; source integrations/planning-tool.env.example; set +a
#
# Plan-step only runs when triage is enabled (MESH_PLANNER_CLI set). The plan the
# tool produces lands on the repo blackboard, and its artifact file lands in
# planning-tool/plans-prod/ — visible in the planning-tool UI (node ui/server.mjs,
# http://localhost:7788), which also works standalone without the mesh.

# triage decomposition planner (required for the plan-step to fire at all)
MESH_PLANNER_CLI=claude

# the plan-step: mesh -> plan-cli.sh shim -> plan-tool.sh
MESH_PLAN_CLI=/Users/george/Documents/Code/agent-mesh/integrations/plan-cli.sh
PLAN_TOOL=/Users/george/Documents/Code/planning-tool/plan-tool.sh

# opus planning is the eval-proven lever; reviewer pass can exceed the 5m default
MESH_PLAN_MODEL=opus
MESH_PLAN_TIMEOUT=15m

# jobs name repos relative to this dir (e.g. repo "ms-monolith")
MESH_REPOS_DIR=/Users/george/Documents/Code
